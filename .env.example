# ============================================================
# Radar Marches Publics - Variables d'environnement v8.1
# Copier ce fichier en ".env" et remplir les valeurs
# ============================================================

# --- Supabase (obligatoire) ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Portail marchespublics.gov.ma (optionnel, pour pack avance) ---
PORTAL_LOGIN=votre_login_portail
PORTAL_PASSWORD=votre_mot_de_passe

# --- Telegram ---
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# --- IA : choisir une option ---

# Option A : Ollama local (RTX 5090 / GPU puissant)
# Lancer "ollama serve" sur ce PC, puis "ollama pull qwen2.5:32b"
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b

# Option B : Claude Haiku cloud (fallback ou mode cloud seul)
# Cle API Anthropic sur https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Option C : Desactiver l'IA (laisser les deux variables vides)
# OLLAMA_URL=
# ANTHROPIC_API_KEY=
